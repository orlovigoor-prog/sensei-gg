# Riot API Key only for local development (получить на: https://developer.riotgames.com/)
VITE_RIOT_API_KEY=your_api_key_here

# Optional backend endpoint for real AI post-game reviews.
# Example: http://127.0.0.1:8787/api/review
# If empty, Sensei GG uses local rule-based post-game analysis fallback.
VITE_AI_REVIEW_ENDPOINT=

# Server-side AI provider settings.
# These variables are for the local AI review server and must not be exposed as VITE_ vars.
# AI_PROVIDER_API_KEY=your_llm_provider_key
# AI_PROVIDER_URL=https://api.deepseek.com/chat/completions
# AI_PROVIDER_MODEL=deepseek-chat
# AI_REVIEW_HOST=127.0.0.1
# AI_REVIEW_PORT=8787

# Примечания:
# - Никогда не коммитьте реальный ключ в git
# - Пользовательский ввод ключа в приложении отключен
# - Для production используйте серверное или платформенное хранение ключа
# - LLM/API ключи для AI review не должны храниться в клиентском UI
# - Соблюдайте rate limits Riot API (1 запрос в секунду для dev ключа)
