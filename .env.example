# Riot API Key only for local backend development (получить на: https://developer.riotgames.com/)
# This key must stay server-side and must not use a VITE_ variable.
RIOT_API_KEY=your_api_key_here

# Optional backend endpoint for real AI post-game reviews.
# Example: http://127.0.0.1:8787/api/review
# If empty, Sensei GG uses local rule-based post-game analysis fallback.
VITE_AI_REVIEW_ENDPOINT=

# Server-side AI provider settings.
# These variables are for the local AI review server and must not be exposed as VITE_ vars.
# AI_PROVIDER_API_KEY=your_llm_provider_key
# AI_PROVIDER_URL=https://api.deepseek.com/chat/completions
# AI_PROVIDER_MODEL=deepseek-chat
# AI_OPENROUTER_API_KEY=your_openrouter_key
# AI_OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
# AI_OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
# AI_REVIEW_HOST=127.0.0.1
# AI_REVIEW_PORT=8787

# Overwolf App Subscriptions API / Tebex foundation.
# These variables are safe for local backend configuration and future integration wiring.
# OVERWOLF_SUBSCRIPTION_STORE_ID=your_overwolf_tebex_store_id
# OVERWOLF_SUBSCRIPTION_PREMIUM_PLAN_ID=12345
# SUBSCRIPTION_DEV_PLAN=free
# SUBSCRIPTION_PROVIDER=overwolf-tebex
# Dev switching is also available at runtime via POST /api/subscription/dev-state for local Overwolf tests.

# Примечания:
# - Никогда не коммитьте реальный ключ в git
# - Пользовательский ввод ключа в приложении отключен
# - Для production используйте серверное или платформенное хранение ключа
# - LLM/API ключи для AI review не должны храниться в клиентском UI
# - OpenRouter free модели могут меняться и имеют низкие rate limits, поэтому это backup, а не production-опора
# - Соблюдайте rate limits Riot API (1 запрос в секунду для dev ключа)
