{
  "manifest_version": 2,
  "type": "web-app",
  "meta": {
    "name": "SenseiGG",
    "version": "1.0.0.0",
    "minimum-overwolf-version": "0.195.0",
    "author": "Sensei",
    "description": "AI-powered League of Legends coach with real-time match analysis",
    "icon": "icon.png"
  },
  "data": {
    "start_window": "desktop",
    "windows": {
      "desktop": {
        "file": "index.html",
        "transparent": true,
        "resizable": true,
        "size": {
          "width": 1280,
          "height": 720
        },
        "min_size": {
          "width": 800,
          "height": 600
        },
        "start_size": {
          "width": 1280,
          "height": 720
        },
        "start_position": "centered"
      }
    }
  },
  "required_capabilities": ["windows"],
  "overwolf_apis": [
    "Windows",
    "KeyboardShortcuts",
    "Profile"
  ]
}
